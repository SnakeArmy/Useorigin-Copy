# ─────────────────────────────────────────────────────────────
# UseOrigin — Environment Variables
# Copy this file to .env and fill in real values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=useorigin_db
POSTGRES_USER=useorigin
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── pgAdmin (optional) ─────────────────────────────────────
PGADMIN_EMAIL=admin@useorigin.dev
PGADMIN_PASSWORD=CHANGE_ME_pgadmin_password

# ── Teller.io API ──────────────────────────────────────────
# Get these from https://teller.io/dashboard
TELLER_APPLICATION_ID=app_XXXXXXXXXXXXXXXX
TELLER_ENVIRONMENT=sandbox
# Path to mTLS certificate & key (mounted in Docker)
TELLER_CERT_PATH=/app/certs/certificate.pem
TELLER_KEY_PATH=/app/certs/private_key.pem

# ── Ollama ──────────────────────────────────────────────────
OLLAMA_MODEL=llama3
